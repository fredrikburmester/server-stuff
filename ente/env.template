# Ente Environment Variables
# Copy to .env and fill in your values

# Paths (for docker-compose)
ENTE_APPDATA=/mnt/user/appdata/ente-photos
ENTE_MINIO=/mnt/user/EntePhotos/minio-data

# MinIO credentials
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your-minio-password

# S3 endpoint (for museum.yaml)
# Use your public domain if exposing MinIO, or internal docker hostname
ENTE_S3_ENDPOINT=https://ente-min.fdrive.se

# Encryption keys - GENERATE NEW ONES with:
# go run tools/gen-random-keys/main.go
ENTE_KEY_ENCRYPTION=your-base64-encryption-key
ENTE_KEY_HASH=your-base64-hash-key
ENTE_JWT_SECRET=your-base64-jwt-secret

# Backblaze B2 (for rclone)
B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-application-key


